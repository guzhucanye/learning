#include<iostream>
#include<queue>
#include<utility>
#include<iomanip>
using namespace std;

int main()
{
    pair<int, int> cli;//到达时刻，办理时间
    queue<pair<int, int> >clis;
    int n;
    int ct=0, t=1, wt=0;    //处理完成时间、现在时间、等待时间
    double sum = 0,aver = 0;
    cin >> n;
    for(int i = 0;i < n;i++)
    {
        cin >> cli.first >> cli.second;
        clis.push(cli);
    }
    t = clis.front().first;  ct = t + clis.front().second;
    clis.pop();
    while(!clis.empty())
    {
        t = clis.front().first;
        if(t > ct)  ct = t;
        wt = ct - t;
        //printf("t=%d, ct=%d, wt=%d\n",t,ct,wt);
        ct += clis.front().second;
        sum += wt;
        clis.pop();
    }
aver = sum / n ;
//cout << fixed << aver << setprecision(2) << endl;
printf("%.2f",aver);
}
