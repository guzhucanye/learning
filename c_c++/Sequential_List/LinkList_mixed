int mixLink_L(LinkList A,LinkList B, LinkList &C)
{
	C = new LNode;
    LinkList p = A->next, q = B->next,r = C;
    C->next = NULL;
    while(p && q)
    {
        if(p->data < q->data)
        {
            r->next = p;
            r = r->next;
            p = p->next;
        }
        else
        {
            r->next = q;
            r = r->next;
            q = q->next;
        }
    }
    while(p)
    {
        r->next = p;
        r = r->next;
        p = p->next;
    }
    while(q)
    {
        r->next = q;
        r = r->next;
        q = q->next;
    }
}

int main()
{
	int n;
	LinkList A, B, C;
	scanf("%d",&n);
	CreateLink_L(A, n);
	scanf("%d",&n);
	CreateLink_L(B, n);
	printf("List A:");
	LoadLink_L(A);
	printf("List B:");
	LoadLink_L(B);
	mixLink_L(A, B, C);
	printf("List C:");
	LoadLink_L(C);
}
