#include <iostream>
#include <stack>  
using namespace std;

int main() {
    stack<int> s;

    s.push(1);
    s.push(2);
    s.push(3);
    s.pop();      
    s.push(76);  

    cout << "栈顶元素：" << s.top() << endl;

    cout << "栈的长度为：" << s.size() << endl;

    cout << "栈内元素（从顶到底）：";
    while (!s.empty()) {
        cout << s.top() << " ";
        s.pop();
    }
    cout << endl;

    return 0;
}
