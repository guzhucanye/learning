#include<iostream>
#include<vector>
#include<string>

using namespace std;

int main()
{	
	vector<int> a;		//定义一个空的vector
	vector<int> b(2);	//定义一个有两个元素的vector默认为0
	vector<int> c(2,2);	//定义有两个元素的vector默认值为2
	
	for(auto it = c.begin();it < c.end();it++)	//迭代器，遍历
	{
		cout << (*it) << " ";
	}
	cout << endl;
	
	a.resize(3);  	//改变序列长度，超出的删除,扩展的填入默认值
	a.resize(4,4); //同上，但用4填入拓展
	cout << "a.size()=" <<a.size() << endl;
	
	
	for(auto it = b.begin();it < b.end();it++)
	{
		cout << (*it) << " ";
	}
	cout << endl;
	b.push_back(4);
	for(auto it = b.begin();it < b.end();it++)
	{
		cout << (*it) << " ";
	}
	cout << endl;
	
	b.pop_back();
	for(auto it = b.begin();it < b.end();it++)
	{
		cout << (*it) << " ";
	}
	cout << endl;
	
	
return 0;
}
