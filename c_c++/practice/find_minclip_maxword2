#include<iostream>
#include<map>
#include<set>
#include<vector>
using namespace std;
int main(){
	int n,m;
	string a;
	cin >> n;
	set<string>need;
	for(int i = 0;i < n;i++){
		cin >> a;
		need.insert(a);
	}
	cin>> m;
	vector<string>words(m);
	for(int i = 0;i < m;i++){
		cin >> a;
		words[i] = a;
	}
	
	int l,r;
	l = r =0;
	int min, max,cur;	//最小长度、最大单词量、目前单词量
	max = cur = 0; min = m+1;
	map<string,int>ct;
	for(;r < m;r++){
		if(need.count(words[r])){
			if(ct[words[r]]==0)
            {
                cur++;
            }
            ct[words[r]]++;
		}
		while(1){
			if(!need.count(words[l]) ){l++;}
			else if(need.count(words[l]) && ct[words[l]] > 1){
				ct[words[l]]--;	l++;	
			}
			else{break;}	
		}
		if(cur > max){
			max = cur; min = r-l+1;
		}
		else if(cur == max){
			if(min > r-l+1){min = r-l+1;}
		}
	}
	
	cout<< max <<" "<< min;
}
