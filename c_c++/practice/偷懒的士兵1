#include<iostream>
#include<algorithm>
#include<map>
using namespace std;
int f(int n,int s, int step){
    if(n==3)return 999999;
    if(n<3) return s;
    else {return min(f(n/2,s+step,step*2),f((n+1)/2,s,step*2));}
}
int main(){
    int n;
    while(cin >> n && n){
        int q = f(n,1,1);
        if(q==999999) {
            cout << '0' << '\n';
        }
        else{cout << q << '\n';}
    }
}
