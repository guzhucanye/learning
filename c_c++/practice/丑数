#include<iostream>
#include<queue>
#include<vector>
#include<set>
typedef  long long ll;
const int coff[3]={2,3,5};
using namespace std;
int main(){
    ios::sync_with_stdio(false);
    int n;
    cin >> n;
    int a[n];
    for(int i = 0; i < n;i++){
        cin >>a[i];
    }
    priority_queue<ll,vector<ll>,greater<ll> > Q;
    set<ll> ug;
    Q.push(1);
    ug.insert(1);
    ll x,x1;
    int m=0;
    for(ll i = 1;i <= a[n-1];i++){
        x = Q.top();
        Q.pop();
        if(i == a[m]){
            cout << x << "\n";  m++;
        }
        for(int j = 0;j < 3;j++){
            x1 = x * coff[j];
            if(!ug.count(x1)){
                Q.push(x1);
                ug.insert(x1);
            }
        }
    }

}
