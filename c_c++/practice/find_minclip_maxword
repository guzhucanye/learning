#include<iostream>
#include<vector>
#include<set>
using namespace std;
int main(){
	vector<string>words;	//单词
	vector<string>art;	//文章
	set<string>target;
	//初始化
	string word;
	int n,m;
	cin >> n;
	for(int i=0; i<n;i++){
		cin >> word;	words.push_back(word);
	}
	cin >> m;
	for(int i=0; i<m;i++){
		cin >> word;	art.push_back(word);
	}
	
	int min = m,max = 0,cur = 0,k = 1,istar = 0; 	//最小长度、最大单词量、目前单词量、目前长度
	int l=0,r=0;	//左右指针
	while(r<art.size() ){
		//首尾相同减去,尾部重复减去
		while( art[r]==art[l] && r!=l){
			l++;	k--;
			target.erase(art[r]);
		}
		while(art[l]==art[l+1] && 1<r){
			l++;	k--;
		}
		istar=0;
		for(int i = 0;i < n;i++){
			//弹出尾部无用单词
			if(art[l] == words[i])	{istar = 1;}
			if(i ==n-1 && istar == 0){l++; k--;}
			
			if(art[r] == words[i]){
				target.insert(art[r]);
				cur = target.size();
				if(cur > max){
					min = k;	max = cur;
				}
				else if(cur == max && k < min){
					min = k;
				}
			}
		}
		if(max == m && min == m)	{break;}
		r++;	k++;
	}
	
	if(max==0){min = 1;}

	cout << max << "\n" << min;
}
