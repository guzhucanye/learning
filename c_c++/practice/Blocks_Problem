#include<iostream>
#include<vector>
using namespace std;

const int MAXN = 30;

vector<int>pile[MAXN];

void find(int a, int &p, int &h)
{
	for(p = 0; p < MAXN; p++)
	{
		for(h = 0; h < pile[p].size();h++)
		{
			if(pile[p][h] == a)	return;
		}
	}
}

void clear(int p, int h)
{
	while(h < pile[p].size()-1)//
	{
		int temp = pile[p][h+1];
		pile[temp].push_back(temp);
		h++;
	}
	pile[p].erase(pile[p].begin()+h+1, pile[p].end());//应该是+1而不是-1
}

void pile_over(int pa, int h, int pb)
{
	while(h < pile[pa].size())
	{
		int temp = pile[pa][h];
		pile[pb].push_back(pile[pa][h]);
		h++;
	}
	pile[pa].erase(pile[pa].begin()+h, pile[pa].end());

}

int main()
{
	int n;
	cin >> n;
	for (int i = 0;i < n;i++)
	{
		pile[i].push_back(i);	
	}
	string cmd,pos;
	int a, b;
	int pa, pb, ha, hb;
	while(cin >> cmd && cmd != "quit")
	{
		cin >> a >> pos >> b;
		find(a, pa, ha);
		find(b, pb, hb);
		
		if(pa == pb)	continue;
		if(pos == "onto")
			clear(pb, hb);
		if(cmd == "move")
			clear(pa, ha);
		pile_over(pa, ha, pb);//很妙的一步，若a上全部归位也可以理解为pile
	}
	for(int i = 0;i < n; i++)
	{
		cout << i << ":" <<" ";
		for(int t = 0;t < pile[i].size(); t++)
		{
			cout << pile[i][t];
			if(t != pile[i].size())	cout << " ";
		}
		cout << endl;
	}		
}
