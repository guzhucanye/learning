/*校赛结束了，每一个参赛选手由3个数据项构成（通过题数，用时分钟数，姓名），排名按照通过题数排序
通过题数多的排前，同题数的，罚时少的排前。如果题数相同，罚时也相同，而按数据读取的先后排。
给你N个参赛选手的数据，按排序先后，输出姓名

输入格式
第一个数为N，（N<=500000）
此后，每行一个参赛选手的数据，通过题数，用时分钟数，姓名，前两者为整型数，姓名为字符串（不多于20个字符）

输出格式
姓名排名

输入样例
4
3 5 Jon
5 100 Smith
3 5 Tom
6 95 Hel

输出样例
Hel
Smith
Jon
Tom
*/
#include<iostream>
#include<algorithm>
#include<queue>
#include<string>
#include<vector>
#include<set>
typedef  long long ll;
using namespace std;
struct record{
    int num;
    int time;
    int order;
    string name;
}; 
bool judgeRank(struct record A,struct record B){
    if(A.num > B.num){return true;}
    else if(A.num == B.num && A.time < B.time){return true;}
    else if(A.num == B.num && A.time == B.time && A.order < B.order){return true;}
    else {return false;}
}
int main(){
    ios::sync_with_stdio(false);
    int n;
    cin >> n;
    vector<struct record> datas;
    record a;
    for(int i = 0; i < n;i++){
        a.order = i;
        cin >> a.num >> a.time >> a.name;
        datas.push_back(a);
    }
    sort(datas.begin(),datas.end(),judgeRank);
    for(auto &a : datas){
        cout << a.name << "\n";
    }
}
