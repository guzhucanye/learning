/*
输入格式
输入文件有2行。第1行是整数n和k，分别表示测量点的个数和博士要求的最大水深差(也就是河床地势差)。第2行有n个整数，表示从上游开始依次得到的水位深度di(1≤i≤n, 0≤di≤32767)。
输出格式
输出文件只有1行，是整数m，表示最长一段起伏不超过k的河流长度，用测量点个数表示。
输入样例
6 2 5 3 2 2 4 5
输出样例
4
*/
#include<iostream>
#include<vector>
#include<set>
#define MAXN 30005
using namespace std;
int main(){
 	ios::sync_with_stdio(false);
	int n,range,river=0;	//n个数，极差range
	vector<int> r;
	multiset<int> cur_r;
	cin >> n >> range;
	
	for(int i=0;i < n;i++){
		cin >> river;
		r.push_back(river);
	}
	
	int i, j, max, min, k=0;
	i = j = 0; max = min = r[0];
	cur_r.insert(r[0]);
	while(j < r.size()){
		if(max - min <= range){
			if(j-i+1 > k)	k = j-i+1;
			j++;
			if(j >= r.size())	{break;}
			cur_r.insert(r[j]);
			if(r[j] > max)	max = r[j];
			if(r[j] < min)	min = r[j];
		}
		else{
			auto it = cur_r.find(r[i]);
			cur_r.erase(it);
			i++;
			min = *cur_r.begin();
			max = *cur_r.rbegin();
		}
	}
	
	cout << k << endl;
	
return 0;
}
