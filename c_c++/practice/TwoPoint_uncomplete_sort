#include<iostream>
#include<vector>
#include<sstream>
using namespace std;

int main(){
	int t,n,x;
	cin >> t;
	for(int p = 0;p < t;p++){
		string line;
		vector<int> s;
		cin >>n;
		cin.ignore(1024,'\n');
		//for(int i = 0;i<t;i++){
			getline(cin, line);
			stringstream ss(line);
			while(ss >> x){
				s.push_back(x);
			}
		//}

		int i = 0,j = s.size()-1,temp;
		while(i < j){
			while(i<j && s[i] < 0){
				i++;
			}
			while(i<j && s[j] > 0){
				j--;
			}
			if(s[i] > 0 && s[j] < 0){
				temp = s[i];
				s[i] = s[j];
				s[j] = temp;
				i++; j--;
	 		}
		}
		for(int i : s){
			cout << i << " "; 
		}
		cout << '\n';
	}
}
