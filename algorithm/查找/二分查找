#include<iostream>
using namespace std;
int f(int *a,int s, int e,int k){
    if(s>e)return -1; 
       int mid = (s+e)/2;
       if(k == a[mid])  return mid;
       else if(k <a[mid]){
            return f(a,s,mid-1,k);
        }
        else{
            return f(a,mid+1,e,k);
        }
    return -1;
}
