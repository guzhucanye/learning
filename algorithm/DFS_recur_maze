#include<iostream>
#include<stack>
#include<vector>
using namespace std;

    int n,m;	
	int sx,sy,ex,ey;
	vector<vector<int>> maze;
	vector<vector<int>> visited;
	int dx[] = {0 ,0,-1,1};
	int dy[] = {-1,1,0,0};	//上下左右
	int min_step = 2147483647;
void dfs (int x, int y ,int step)
{
	if (x == ex && y == ey) {
        if (step < min_step) {
            min_step = step;
        }
        return; //返回到上一层
    }
    
    for(int i = 0;i < 4;i++)
	{
		int nx = x + dx[i], ny = y + dy[i];
		if(nx<0 || nx>=n || ny<0 || ny>=m )	continue;
			if(maze[nx][ny] == 0 && visited[nx][ny] == 0)
			{
				visited[nx][ny] = 1;
				dfs(nx, ny, step+1);
				visited[nx][ny] = 0;
			}
	}
}
int main()
{	
	cin >> n >> m;
	cin >> sx >> sy >> ex >> ey;
	maze.resize(n, vector<int>(m));
    visited.resize(n, vector<int>(m, 0));
	for(int i = 0;i < n;i++)
	{
		for(int j = 0;j < m;j++)
		{
			cin >> maze[i][j];
		}	
	}
	visited[sx][sy] = 1;
	dfs(sx, sy, 0);	

	if (min_step != 2147483647) 	 cout << min_step << endl;
	else    cout << -1 << endl;
return 0;
}
