#include<iostream>
#include<queue>
#include<vector>
using namespace std;
#define x first 
#define y second 
int main()
{
	int n,m;	
	cin >> n >> m;
	int sx,sy,ex,ey;
	cin >> sx >> sy >> ex >> ey;
	int maze[n][m] = {0};	//x,y
	int dist[n][m] = {-1};
	queue<pair<int,int> > w; 	//x,y
	int dx[] = {0 ,0,-1,1};
	int dy[] = {-1,1,0,0};	//上下左右
	for(int i = 0;i < n;i++)
	{
		for(int j = 0;j < m;j++){
			cin >> maze[i][j];
		}
	}
	w.push({sx,sy});
	dist[sx][sy] = 0;
	
	while(w.size() && !w.empty())
	{
		auto t = w.front();
		w.pop();
		if(t.x == ex && t.y == ey)
			{
				cout << dist[t.x][t.y];
				return dist[t.x][t.y];
			}
		for(int i = 0;i < 4;i++)
		{
			int nx = t.x + dx[i], ny = t.y + dy[i];
			if(nx<0 || nx>n || ny<0 || ny>m )	continue;
			if(maze[nx][ny] != 0)	continue;
			if(dist[nx][ny] > 0)	continue;
			w.push({nx, ny});
			dist[nx][ny] = dist[t.x][t.y] + 1;
			
		}
	}
	cout << "-1";
return -1;	
}
